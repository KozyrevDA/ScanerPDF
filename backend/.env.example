# API-ключ AI-провайдера. НИКОГДА не коммитьте реальный ключ.
ANTHROPIC_API_KEY=
# Модель провайдера
ANTHROPIC_MODEL=claude-sonnet-4-6
# Лимит размера входного текста (символов)
MAX_TEXT_CHARS=60000
# Таймаут запроса к провайдеру (секунды)
UPSTREAM_TIMEOUT_S=45
# Rate limit на IP (запросов в минуту)
RATE_LIMIT_PER_MINUTE=20
